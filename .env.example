# Copia este archivo a .env y rellena los valores. No subas .env al repositorio.

# OpenAI (Healing Agent / reparación con IA)
OPENAI_API_KEY=
OPENAI_REMEDIATION_MODEL=gpt-4o-mini

# Opcional: TTL en días para reglas de reparación cacheadas (por defecto 7)
# REPAIR_RULE_TTL_DAYS=7

# Opcional: tests de integración (URL del endpoint de ingest)
# SENTINEL_INGEST_URL=http://localhost:3111/ingest
