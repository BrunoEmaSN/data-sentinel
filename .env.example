# Copy this file to .env and fill in the values. Do not commit .env to the repo.
# Pipeline behaviour is configured in sentinel-config.yaml; here only secrets and overrides.

# OpenAI (Healing Agent / LLM remediation)
OPENAI_API_KEY=

# Optional: override sentinel-config.yaml
# OPENAI_REMEDIATION_MODEL=gpt-4o-mini
# REPAIR_RULE_TTL_DAYS=7

# Optional: path to config file (default: sentinel-config.yaml at project root)
# SENTINEL_CONFIG_PATH=/path/to/sentinel-config.yaml

# Optional: integration tests (ingest endpoint URL)
# SENTINEL_INGEST_URL=http://localhost:3111/ingest
